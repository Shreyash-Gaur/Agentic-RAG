# ==========================================
# API
# ==========================================
API_TITLE=Agentic RAG API
API_VERSION=1.0.0

# Explicit origins — correct. Wildcard + credentials is rejected by browsers.
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Set to true only for local development — enables auto-reload and verbose errors.
DEBUG=false

# ==========================================
# HuggingFace
# ==========================================
HF_TOKEN=your_huggingface_token

# ==========================================
# OLLAMA
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
EMBEDDING_MODEL=mxbai-embed-large:latest

# ==========================================
# GENERATION BEHAVIOUR
# ==========================================
# qwen2.5:7b supports up to 128k context — 1024 gives much richer answers
# than the original 512 default without hitting memory limits.
MAX_TOKENS=1024

# Max LangGraph retries before forcing a response regardless.
# 3 is enough — beyond this you're just burning time on a bad query.
MAX_ITERATIONS=3

# ==========================================
# PATHS & DATABASES
# ==========================================
WATCH_DIR=knowledge
FAISS_INDEX_PATH=backend/db/vector_data/knowledge_faiss.index
FAISS_META_PATH=backend/db/vector_data/knowledge_meta.jsonl
META_DB_PATH=backend/db/vector_data/metadata_store.db

MEMORY_DB_PATH=backend/db/memory/memory_store.sqlite
EMBEDDING_CACHE_DB=backend/db/embedding_cache/embed_cache.sqlite

# How many conversation turns to keep in memory context per session.
# 20 is enough for multi-turn without bloating the prompt.
MEMORY_MAX_TURNS=20

# ==========================================
# CHUNKING  (affects ingestion quality)
# ==========================================
# 512 tokens per chunk is the sweet spot for mxbai-embed-large.
# Going larger hurts embedding precision; smaller loses context continuity.
CHUNK_TOKENS=512
CHUNK_OVERLAP=100

# How many chunks to embed in one Ollama batch call.
# 16 is safe for 8GB VRAM; lower to 8 if you see OOM during ingestion.
EMBEDDING_BATCH_SIZE=16

# ==========================================
# RETRIEVAL
# ==========================================
# With the agentic multi-step planner, each retrieve step pulls TOP_K chunks.
# 2-3 plan steps × 5 chunks = 10-15 chunks before reranking — rich enough
# context without overflowing qwen2.5:7b's prompt budget.
TOP_K_RETRIEVAL=5

# HyDE is correctly implemented here — embeds the hypothetical document alone,
# not concatenated with the raw query. Keep enabled: it meaningfully improves
# retrieval precision at no cost beyond one extra LLM call per query.
USE_HYDE=true

# ==========================================
# RERANKER
# ==========================================
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# "cross-encoder" uses sentence-transformers CrossEncoder directly.
# "flag" uses FlagEmbedding — marginally faster but requires an extra install.
RERANKER_BACKEND=cross-encoder

# How to normalise raw CrossEncoder scores before comparing them.
# "sigmoid" maps scores to [0, 1] and is the safest default.
# "minmax" and "softmax" are alternatives if you want relative ranking.
RERANKER_NORMALIZE=sigmoid

# Batch size for the reranker's scoring pass. 8 is safe for 8GB VRAM.
RERANKER_BATCH_SIZE=8

# Initial candidate pool for the reranker.
# Rule of thumb: 3× TOP_K_RETRIEVAL. With TOP_K=5 → pull 15, return top 5.
RERANKER_INITIAL_K=15

# ==========================================
# SEMANTIC CACHE
# ==========================================
SEMANTIC_CACHE_MODEL=BAAI/bge-large-en-v1.5

# 0.85 is tighter than the original 0.80 default.
# At 0.80 you risk cache hits on questions that are similar but not the same
# (e.g. "what is X?" vs "how does X work?"). 0.85 avoids false positives
# while still catching genuine repeats.
SEMANTIC_CACHE_THRESHOLD=0.85

# ==========================================
# FRONTEND
# ==========================================
CHAINLIT_ENABLED=true

